# AppServer
APPSERVER_RELEASE=12.1.2410
APPSERVER_VERSION="${APPSERVER_RELEASE}"
APPSERVER_BUILD_VERSION=24.3.1.1
APPSERVER_WEBAPP_VERSION=10.1.4
