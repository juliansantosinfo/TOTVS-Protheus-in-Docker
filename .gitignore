# ==============================================================================
# TOTVS Protheus in Docker - Master Gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Environment and Local Settings
# ------------------------------------------------------------------------------
**/.env
**/.venv/

# ------------------------------------------------------------------------------
# 2. OS and IDE Specific Files
# ------------------------------------------------------------------------------
.DS_Store
**/.idea/
Thumbs.db

# ------------------------------------------------------------------------------
# 3. Project Temporary and Volume Data
# ------------------------------------------------------------------------------
**/temp/
**/Temp/
**/volume/

# ------------------------------------------------------------------------------
# 4. TOTVS Binaries, Resources and Large Files
# ------------------------------------------------------------------------------
# AppServer & RPOs
services/appserver/totvs/protheus.tar.gz
services/appserver/totvs/protheus_data.tar.gz

# DBAccess
services/dbaccess/totvs/dbaccess

# License Server
services/licenseserver/totvs/licenseserver

# Database Resources
services/mssql/resources/data.tar.gz
services/oracle/resources/data.tar.gz
services/postgres/resources/data.tar.gz
**/LINUX.X64_213000_db_home.zip

# SmartView
services/smartview/totvs/smartview.tar.gz

# Component Packages (Local download cache)
**/packages/**
!**/packages/
!**/packages/.gitkeep

# ------------------------------------------------------------------------------
# 5. Tooling and AI Assistants
# ------------------------------------------------------------------------------
# Gemini CLI/Agent
**/.gemini/
**/GEMINI.md
**/.geminiignore

# AmazonQ / CodeWhisperer
.amazonq/
